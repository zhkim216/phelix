Bootstrap: docker
From: nvidia/cuda:12.6.3-base-ubuntu24.04

%files
    __PHELIX_JACKHMMER_PATCH__ /tmp/jackhmmer_seq_limit.patch

%post
    set -eux

    export DEBIAN_FRONTEND=noninteractive
    apt-get update --quiet
    apt-get install --yes --quiet \
        ca-certificates \
        curl \
        git \
        wget \
        gcc \
        g++ \
        make \
        patch \
        python3.12 \
        python3.12-dev \
        python3.12-venv \
        python3-pip \
        zlib1g-dev \
        zstd
    rm -rf /var/lib/apt/lists/*

    # Install uv into a system path. The Python environment itself is created
    # later on Sherlock scratch by install_phelix_sherlock.sh.
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh
    uv --version

    # Build patched HMMER 3.4 for AlphaFold3 data pipeline support.
    mkdir -p /hmmer_build /hmmer
    wget http://eddylab.org/software/hmmer/hmmer-3.4.tar.gz --directory-prefix /hmmer_build
    cd /hmmer_build
    echo "ca70d94fd0cf271bd7063423aabb116d42de533117343a9b27a65c17ff06fbf3 hmmer-3.4.tar.gz" | sha256sum --check
    tar zxf hmmer-3.4.tar.gz
    patch -p0 < /tmp/jackhmmer_seq_limit.patch
    cd /hmmer_build/hmmer-3.4
    ./configure --prefix /hmmer
    make -j"$(nproc)"
    make install
    cd /hmmer_build/hmmer-3.4/easel
    make install
    rm -rf /hmmer_build /tmp/jackhmmer_seq_limit.patch

    /hmmer/bin/jackhmmer -h | grep -- --seq_limit

%environment
    export PATH="/hmmer/bin:/usr/local/bin:$PATH"
    export UV_COMPILE_BYTECODE=1

%labels
    Author zhkim216
    Project phelix
    Description "Phelix AlphaFold3-new Sherlock base image with Python 3.12, uv, zlib headers, and patched HMMER 3.4"
